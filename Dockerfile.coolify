FROM node:22-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends git gh ca-certificates openssh-client \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json pnpm-lock.yaml ./
RUN corepack enable \
  && corepack prepare pnpm@10.27.0 --activate \
  && pnpm install --frozen-lockfile

COPY . .
RUN pnpm build \
  && mkdir -p /app/results /app/Sessions/connected-repos

ENV NODE_ENV=production
EXPOSE 4200

CMD ["pnpm", "start"]
