# -- OpenAI (optional; required if you select a gpt-* model in the dashboard) --
# OPENAI_API_KEY=sk-proj-...
# Optional project / org (use the project id from platform.openai.com/settings, often proj_...)
# OPENAI_PROJECT_ID=proj_...
# OPENAI_ORG_ID=org_...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_RATE_LIMIT_RETRIES=12

# -- Anthropic ----------------------------------------------------------------
# Standard API key (sk-ant-...). Not needed if using OAuth or Claude Code Keychain auth.
ANTHROPIC_API_KEY=sk-ant-...

# Alternative: OAuth token (bypasses API key).
# ANTHROPIC_AUTH_TOKEN=

# Optional: custom base URL (e.g., local proxy for Claude Max plan).
# ANTHROPIC_BASE_URL=http://localhost:3000

# Optional: extra 429/rate_limit retries per messages.create (default 14).
# ANTHROPIC_RATE_LIMIT_RETRIES=14

# Optional: cheaper models for local smoke tests (restart server after change).
# Planning/review default to Opus; coding/summary default to Sonnet. Overriding
# all roles to Haiku cuts cost for "does the loop work?" checks (quality drops).
# SHIPYARD_PLANNING_MODEL=claude-haiku-4-5
# SHIPYARD_CODING_MODEL=claude-haiku-4-5
# SHIPYARD_REVIEW_MODEL=claude-haiku-4-5
# SHIPYARD_VERIFICATION_MODEL=claude-haiku-4-5
# SHIPYARD_SUMMARY_MODEL=claude-haiku-4-5
# SHIPYARD_INTENT_MODEL=claude-haiku-4-5
# SHIPYARD_CHAT_MODEL=claude-haiku-4-5
#
# Per-run: dashboard `/settings` saves family + per-stage models (localStorage). Each run
# can also pass `modelFamily` + `models` on `POST /api/run` or WebSocket `submit`.
# Legacy: body field `model` overrides coding only for that run.

# -- Server -------------------------------------------------------------------
SHIPYARD_PORT=4200

# Working directory for file operations (the target repo the agent edits).
# Defaults to cwd if unset.
SHIPYARD_WORK_DIR=/path/to/target-repo

# Optional: Bearer token for API auth. When set, all endpoints except /api/health
# require Authorization: Bearer <key>.
# SHIPYARD_API_KEY=

# -- Database (optional) ------------------------------------------------------
# PostgreSQL connection string. Enables persistent run storage.
# Falls back to in-memory if unset or unreachable.
# SHIPYARD_DB_URL=postgresql://localhost/shipyard
# On first write the server adds token_input/token_output if missing (see
# scripts/migrations/002-add-token-columns.sql).

# -- LangSmith Tracing (optional) ---------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=shipyard
