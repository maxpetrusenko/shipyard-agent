# API key: real sk-ant-... for console billing, or any non-empty string when using
# Claude Max via anthropic-max-router (see ANTHROPIC_BASE_URL below).
ANTHROPIC_API_KEY=sk-ant-...
# Optional: local proxy that authenticates with your Max plan (OAuth), e.g.
# ANTHROPIC_BASE_URL=http://localhost:3000
# ANTHROPIC_API_KEY=dummy

LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ship-agent
SHIPYARD_PORT=4200
# Required for dev unless you always start the server from the target repo root.
SHIPYARD_WORK_DIR=/path/to/ship-refactored
