# ── Anthropic ────────────────────────────────────────────────────
# Standard API key (sk-ant-...). Not needed if using OAuth or Claude Code Keychain auth.
ANTHROPIC_API_KEY=sk-ant-...

# Alternative: OAuth token (bypasses API key).
# ANTHROPIC_AUTH_TOKEN=

# Optional: custom base URL (e.g., local proxy for Claude Max plan).
# ANTHROPIC_BASE_URL=http://localhost:3000

# ── Server ───────────────────────────────────────────────────────
SHIPYARD_PORT=4200

# Working directory for file operations (the target repo the agent edits).
# Defaults to cwd if unset.
SHIPYARD_WORK_DIR=/path/to/target-repo

# Optional: Bearer token for API auth. When set, all endpoints except /api/health
# require Authorization: Bearer <key>.
# SHIPYARD_API_KEY=

# ── Database (optional) ─────────────────────────────────────────
# PostgreSQL connection string. Enables persistent run storage.
# Falls back to in-memory if unset or unreachable.
# SHIPYARD_DB_URL=postgresql://localhost/shipyard

# ── LangSmith Tracing (optional) ────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=shipyard
